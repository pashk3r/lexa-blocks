@startuml
title Class Diagram - Lexa-Blocks (v1.0)

interface IEduService {
    + generateQuestion(): MathQuestion
    + verifyAnswer(questionId: string, selectedOption: string): bool
}

class GameManager {
    - field: Field
    - scoreSystem: ScoreSystem
    - saveCubesManager: SaveCubesManager
    - currentFigures: List<Figure>   ' 3 фигуры
    - gameState: GameState
    - eduService: IEduService
    + placeFigure(figure: Figure, position: Position): bool
    + onNoMovesLeft()
    + onMathHelpRequested()
    + onAnswer(selectedOption: string)
    + onSurrender()
    + useSaveCube(position: Position): bool
    + restartGame()
    + checkGameOver(): bool
}

enum GameState {
    PLAYING
    LOSS_MENU
    WAITING_MATH_ANSWER
}

class Field {
    - width: int = 8
    - height: int = 8
    - grid: Cell[][]
    + canPlace(figure: Figure, pos: Position): bool
    + placeFigure(figure: Figure, pos: Position): void
    + clearFullRowsAndColumns(): int   ' возвращает количество очищенных линий
    + reset()
}

class Cell {
    - occupied: bool
}

class Figure {
    - shape: List<Point>   ' относительные координаты кубов
    + getCubesCount(): int
    + static getRandomFigures(count: int): List<Figure>
}

class ScoreSystem {
    - totalScore: int
    + addPointsForCubes(cubesCount: int)
    + addPointsForLines(linesCount: int)
    + getLevel(): int
    + getProgress(): int   ' 0..99
    + reset()
}

class MathQuestion {
    + id: string
    + text: string
    + options: List<string>   ' 4 элемента: A, B, C, D
    + correctOption: string   ' 'A'..'D'
}

class RemoteMathAPI implements IEduService {
    - baseUrl: string
    + generateQuestion(): MathQuestion
    + verifyAnswer(questionId, selectedOption): bool
}

class SaveCubesManager {
    - count: int
    + add(amount: int)
    + use(): bool
    + getCount(): int
    + reset()
}

GameManager --> IEduService
GameManager *-- Field
GameManager *-- ScoreSystem
GameManager *-- SaveCubesManager
GameManager --> GameState
Field o-- Cell
Figure <.. GameManager : uses
RemoteMathAPI ..|> IEduService
RemoteMathAPI --> MathQuestion : creates

note top of ScoreSystem : Уровень = floor(totalScore/100)+1\nПрогресс = totalScore % 100
note top of Field : Очистка строк и столбцов\n1 линия = 10 очков (но начисляет ScoreSystem)
@enduml
