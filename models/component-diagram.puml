@startuml
title Component Architecture - Lexa Blocks

package "GameCore" {
    component "Game" as GameComp
    component "GameState" as GameStateComp
    component "Board" as BoardComp
    component "Block" as BlockComp
    component "Renderer" as RendererComp
    component "EventHandler" as EventHandlerComp
}

package "QuizPlugin" {
    component "QuizPlugin" as QuizPluginComp
    component "BasePlugin" as BasePluginComp
}

package "External API Client" {
    component "api_client" as APIClient <<module>>
}

component "DeepSeek API" as DeepSeek <<external>>

' Зависимости
GameComp --> QuizPluginComp : uses
QuizPluginComp --|> BasePluginComp : extends
QuizPluginComp --> APIClient : calls
APIClient --> DeepSeek : HTTP POST

note right of QuizPluginComp
    Реализует логику спасения:
    - перехватывает game_over
    - загружает вопрос через API
    - отображает варианты ответа
    - выдаёт спасательные кубы
end note

@enduml
