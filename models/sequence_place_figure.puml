@startuml
title Диаграмма последовательности - Размещение фигуры (UC-1)

actor "Игрок" as P
participant "GameState" as GC
participant "Board" as F

P -> GC : перетаскивание фигуры на клетку
GC -> GC : try_place_active_block() 'проверка и подготовка размещения
GC -> F : can_place(block, gx, gy)

alt can_place == True
    GC -> F : place(block, gx, gy)
    F -> F : _clear_lines()
    F --> GC : начислено очков (кубы + линии)
    GC -> GC : _add_score(points) 'добавить очки к счёту
    GC -> GC : удалить блок из blocks_in_hand

    alt набор пуст
        GC -> GC : spawn_blocks() 'сгенерировать новый набор фигур
    end

    GC -> GC : _is_game_over() 'проверить наличие возможных ходов
    alt ходов нет
        GC -> GC : game_over = True
    end

else can_place == False
    GC -> GC : активный блок возвращается в слот
    GC --> P : показать ошибку (опционально)
end
@enduml
